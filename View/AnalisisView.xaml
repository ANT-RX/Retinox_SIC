<Window x:Class="Retinox.View.AnalisisView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Análisis - Sistema Retinopatía" 
        Height="540" Width="960"
        WindowStyle="None" 
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" 
        Background="Transparent"
        AllowsTransparency="True">
    <Border Style="{StaticResource EstiloContenedorPrincipal}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="65"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Style="{StaticResource estiloBaseMinSalir}" Content="?" Click="btnAyuda_Click"/>
                <Button Style="{StaticResource estiloBaseMinSalir}" Content="-" Click="btnMinimizar_Click"/>
                <Button Style="{StaticResource estiloBaseMinSalir}" Content="x" Click="btnCerrar_Click"/>
            </StackPanel>

            <TextBlock Grid.Row="1" Style="{StaticResource estiloTitulos}" Text="Análisis" VerticalAlignment="Top" Margin="0,10,0,0"/>

            <Grid Grid.Row="2" Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Form -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Label Content="Seleccionar paciente:" Foreground="#333" FontWeight="Bold" HorizontalAlignment="Left" Margin="25,0,0,0"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                        <ComboBox x:Name="cmbPacientes" 
                                  Style="{StaticResource estiloComboBox}" 
                                  Width="350" Height="40"
                                  ItemsSource="{Binding Pacientes}" 
                                  DisplayMemberPath="DescripcionBusqueda" 
                                  SelectedItem="{Binding PacienteSeleccionado, UpdateSourceTrigger=PropertyChanged}" 
                                  IsEditable="True" 
                                  IsTextSearchEnabled="True" 
                                  Text="{Binding PacienteSeleccionado.DescripcionBusqueda, Mode=OneWay}"
                                  TextSearch.TextPath="DescripcionBusqueda" 
                                  StaysOpenOnEdit="False"/>
                        <Button x:Name="btnNuevoPaciente" 
                                Width="40" Height="40" 
                                Margin="10,0,0,0" 
                                Style="{StaticResource estiloButtonBase}" 
                                Click="btnNuevoPaciente_Click">
                            <TextBlock Text="+" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                    <Button x:Name="btnSelectorImagen" Style="{StaticResource estiloButtonBase}" Width="400" Height="60" Margin="0,30,0,20" Command="{Binding CargarImagenCommand}">
                        <TextBlock Text="📁 Cargar imagen de retina" VerticalAlignment="Center" FontSize="16"/>
                    </Button>

                    <Border BorderBrush="#00796B" BorderThickness="1" CornerRadius="5" Width="400" Height="40" Background="#E0F2F1">
                        <TextBlock x:Name="txtNombreArchivo" Text="{Binding NombreArchivoImagen}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#00796B" FontStyle="Italic" TextTrimming="CharacterEllipsis" Padding="10,0"/>
                    </Border>
                </StackPanel>

                <!-- Right Column: Preview de la Retina -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Label Content="Vista previa de la captura:" Foreground="#333" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Border Width="220" Height="220" Margin="0,15,0,0" BorderBrush="#ccc" BorderThickness="2" CornerRadius="10" Background="#f8f9fa">
                        <Image Source="{Binding RutaArchivoImagenCompleta}" Stretch="UniformToFill" Margin="2">
                            <Image.Clip>
                                <RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,212,212"/>
                            </Image.Clip>
                        </Image>
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                        </Border.Effect>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="20,0">
                <Button Style="{StaticResource estiloButtonBase}" Content="&lt;" Width="60" Height="60" Margin="10,0,0,0" Click="btnAtras_Click"/>
                <Button Style="{StaticResource estiloButtonBase}" Content="&gt;" Width="60" Height="60" HorizontalAlignment="Right" Margin="780,0,0,0" Command="{Binding IrAResultadoCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>