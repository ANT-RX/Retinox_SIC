<Window x:Class="Retinox.View.InicioView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inicio - Sistema Retinopatía" 
        Height="540" Width="960"
        WindowStyle="None" 
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" 
        Background="Transparent"
        AllowsTransparency="True">

    <Border Style="{StaticResource EstiloContenedorPrincipal}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Style="{StaticResource estiloBaseMinSalir}" Content="?" Click="btnAyuda_Click"/>
                <Button Style="{StaticResource estiloBaseMinSalir}" Content="-" Click="btnMinimizar_Click"/>
                <Button Style="{StaticResource estiloBaseMinSalir}" Content="x" Click="btnCerrar_Click"/>
            </StackPanel>

            <TextBlock Grid.Row="1" Style="{StaticResource estiloTitulos}" Text="Inicio"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top">

                <Button Style="{StaticResource estiloButtonBase}" Width="180" Height="200" Margin="20" Click="btnAnalisis_Click">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Análisis" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <Border Background="#00796B" Width="50" Height="50" CornerRadius="5"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource estiloButtonBase}" Width="180" Height="200" Margin="20" Click="btnPacientes_Click">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Pacientes" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <Border Background="#00796B" Width="50" Height="50" CornerRadius="5"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource estiloButtonBase}" Width="180" Height="200" Margin="20" Click="btnHistorial_Click">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Historial" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <Border Background="#00796B" Width="50" Height="50" CornerRadius="5"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</Window>