<Window x:Class="Retinox.View.PacientesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="540" Width="960"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" 
        Background="Transparent" AllowsTransparency="True">

    <Border Style="{StaticResource EstiloContenedorPrincipal}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Style="{StaticResource estiloBaseMinSalir}" Content="?" Click="btnAyuda_Click"/>
                <Button Style="{StaticResource estiloBaseMinSalir}" Content="-" Click="btnMinimizar_Click"/>
                <Button Style="{StaticResource estiloBaseMinSalir}" Content="x" Click="btnCerrar_Click"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Pacientes" Style="{StaticResource estiloTitulos}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="60"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Buscar paciente:" VerticalAlignment="Center" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbNSS" Grid.Row="0" Grid.Column="1" Style="{StaticResource estiloComboBox}" Height="40" ItemsSource="{Binding Pacientes}" DisplayMemberPath="DescripcionBusqueda" SelectedItem="{Binding PacienteSeleccionado, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="DescripcionBusqueda" StaysOpenOnEdit="True"/>

                    <Label Grid.Row="1" Content="Nombre:" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource EstiloTextBoxBase}" Height="40" IsReadOnly="True" Text="{Binding PacienteSeleccionado.Nombre, TargetNullValue='N/A'}"/>

                    <Label Grid.Row="2" Content="Edad:" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource EstiloTextBoxBase}" Height="40" IsReadOnly="True" Text="{Binding PacienteSeleccionado.Edad, TargetNullValue='N/A'}"/>

                    <Label Grid.Row="3" Content="Padecimiento:" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource EstiloTextBoxBase}" Height="40" IsReadOnly="True" Text="{Binding PacienteSeleccionado.Padecimiento, TargetNullValue='N/A'}"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="20">
                <Button Style="{StaticResource estiloButtonBase}" Content="&lt;" Width="60" Height="60" Click="btnAtras_Click"/>
                <Separator Width="780" Background="Transparent"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>